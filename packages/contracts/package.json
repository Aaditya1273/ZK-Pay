{
  "name": "@privacy-pool-core/contracts",
  "version": "1.1.0",
  "description": "ZK-PAY: Privacy Pool on Stellar — Rust Soroban smart contracts",
  "repository": "https://github.com/0xbow-io/privacy-pools-core",
  "license": "Apache-2.0",
  "author": "Wonderland / ZK-Pay",
  "scripts": {
    "build": "cargo build --target wasm32-unknown-unknown --release",
    "build:debug": "cargo build --target wasm32-unknown-unknown",
    "test": "cargo test",
    "test:unit": "cargo test --lib",
    "test:integration": "cargo test --test integration",
    "clean": "cargo clean && rm -rf target/",
    "check": "cargo check",
    "clippy": "cargo clippy --all-targets -- -D warnings",
    "fmt": "cargo fmt",
    "fmt:check": "cargo fmt --check",
    "deploy:testnet": "stellar contract deploy --wasm target/wasm32-unknown-unknown/release/privacy_pool_core.wasm --network testnet",
    "deploy:mainnet": "stellar contract deploy --wasm target/wasm32-unknown-unknown/release/privacy_pool_core.wasm --network public",
    "bindings:generate": "stellar contract bindings generate --contract-id",
    "optimize": "cargo build --target wasm32-unknown-unknown --release && stellar contract optimize --wasm target/wasm32-unknown-unknown/release/privacy_pool_core.wasm"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^12.1.0",
    "soroban-client": "^1.1.0"
  },
  "devDependencies": {
    "soroban-cli": "21.0.0",
    "stellar-cli": "27.0.0"
  }
}
