NEXT_PUBLIC_PROJECT_ID= # ProjectID from WalletConnect
NEXT_PUBLIC_ALCHEMY_KEY= # API key from Alchemy
NEXT_PUBLIC_ASP_ENDPOINT_TEST= # ASP endpoint for test chains (e.g., https://dw.0xbow.io)
NEXT_PUBLIC_ASP_ENDPOINT_NON_TEST= # ASP endpoint for production chains (e.g., https://api.0xbow.io)
NEXT_PUBLIC_TEST_MODE= # Example: true
NEXT_PUBLIC_SHOW_DISCLAIMER= # Example: true
NEXT_PUBLIC_IS_TESTNET= # Example: true
NEXT_PUBLIC_SHOW_TEST_CHAINS= # Example: true (show test chains in All Pools table)
NEXT_PUBLIC_GITHUB_HASH= # Example: "4fdc156"
HYPERSYNC_KEY= # API key from HYPERSYNC
SENTRY_AUTH_TOKEN= # Sentry authentication token
NEXT_PUBLIC_SENTRY_DSN= # Sentry DSN for error tracking
NEXT_PUBLIC_GA_ID= # Google Analytics ID (default: G-D177C1SMBP)

# Migration
NEXT_PUBLIC_IS_MIGRATION_ACTIVE= # Example: true (enable the migration flow)
NEXT_PUBLIC_SHOW_MIGRATION_BANNER= # Example: true (show the migration banner)
NEXT_PUBLIC_MIGRATION_RELAYER_URL= # Migration relayer endpoint URL
NEXT_PUBLIC_MIGRATION_ANNOUNCEMENT_URL= # URL for the migration announcement (e.g., https://blog.0xbow.io/migration)

# Newsletter Subscription
# MailerLite API Key - https://developers.mailerlite.com/docs/authentication.html
MAILERLITE_API_KEY= # Your MailerLite API key

# Turnstile Captcha Keys - https://developers.cloudflare.com/turnstile/get-started/
NEXT_PUBLIC_TURNSTILE_SITE_KEY= # Your Turnstile site key (public)
TURNSTILE_SECRET_KEY= # Your Turnstile secret key (private)
